# Root-level env reference — copy to .env and fill in values

# Postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=indigen
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/indigen

# Redis
REDIS_URL=redis://localhost:6379

# Server
PORT=3001
NODE_ENV=development
JWT_SECRET=change_me_in_production
REFRESH_TOKEN_SECRET=change_me_in_production
CORS_ORIGIN=http://localhost:5173

# Scraper
SCRAPER_SERVICE_URL=http://localhost:8000
LINKEDIN_USERNAME=
LINKEDIN_PASSWORD=

# SignalHire
SIGNALHIRE_API_KEY=

# Cashfree
CASHFREE_APP_ID=
CASHFREE_SECRET_KEY=
CASHFREE_ENV=sandbox
