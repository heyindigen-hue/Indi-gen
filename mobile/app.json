{
  "expo": {
    "name": "LeadHangover",
    "slug": "leadhangover",
    "version": "1.0.0",
    "scheme": "leadhangover",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#FF4716"
    },
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.leadhangover.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FF4716"
      },
      "package": "com.leadhangover.app",
      "permissions": [
        "NOTIFICATIONS"
      ],
      "blockedPermissions": [],
      "softwareKeyboardLayoutMode": "pan"
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "a514eb9b-7483-435e-bfe5-1c4d432c627f"
      }
    },
    "owner": "yashraj-indigen"
  }
}
