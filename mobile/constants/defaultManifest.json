{
  "theme": {
    "palette": "warm-light",
    "mode": "light",
    "radius": 14,
    "density": "comfortable"
  },
  "brand": {
    "name": "LeadHangover",
    "tagline": "Wake up to better leads",
    "logo_light": "",
    "logo_dark": "",
    "primary_color": "#FF5A1F"
  },
  "tabs": [
    { "id": "index", "label": "Home", "icon": "home", "enabled": true, "order": 0 },
    { "id": "explore", "label": "Saved", "icon": "bookmark", "enabled": true, "order": 1 },
    { "id": "leads", "label": "Leads", "icon": "lead", "enabled": true, "order": 2 },
    { "id": "outreach", "label": "Outreach", "icon": "send", "enabled": true, "order": 3 },
    { "id": "insights", "label": "Insights", "icon": "chart-line", "enabled": true, "order": 4 },
    { "id": "settings", "label": "Settings", "icon": "settings", "enabled": true, "order": 5 }
  ],
  "home_widgets": [
    {
      "type": "AnnouncementBanner",
      "props": {
        "message": "Welcome to LeadHangover! Start exploring leads.",
        "dismissible": true
      }
    },
    {
      "type": "TokenBalance",
      "props": {
        "balance": 100,
        "showTopUp": true
      }
    },
    {
      "type": "QuickFilters",
      "props": {
        "filters": ["All", "New", "Hot", "Contacted"]
      }
    },
    {
      "type": "RecentLeadsCarousel",
      "props": {
        "title": "Recent Leads"
      }
    },
    {
      "type": "ActionButtons",
      "props": {
        "actions": [
          { "label": "Find Leads", "action": "navigate:/explore", "variant": "primary" },
          { "label": "Outreach", "action": "navigate:/outreach", "variant": "secondary" }
        ]
      }
    }
  ],
  "onboarding_steps": [
    {
      "id": "welcome",
      "title": "Welcome to LeadHangover",
      "description": "AI-powered lead generation at your fingertips.",
      "input_type": "none"
    },
    {
      "id": "phrases",
      "title": "What leads are you looking for?",
      "description": "Select topics to personalize your feed.",
      "input_type": "chip_select",
      "options": ["SaaS founders", "E-commerce owners", "Startup CTOs", "Marketing managers", "Small business owners", "Freelancers"],
      "field": "phrases"
    },
    {
      "id": "done",
      "title": "Finding your first leads...",
      "description": "We're scanning the web for leads that match your interests.",
      "input_type": "done"
    }
  ],
  "paywall": {
    "title": "Get more leads",
    "subtitle": "Top up tokens or subscribe for unlimited access",
    "token_bundles": [
      { "id": "tokens_100", "tokens": 100, "amount": 499, "label": "₹499", "badge": null },
      { "id": "tokens_500", "tokens": 500, "amount": 1999, "label": "₹1,999", "badge": "POP" },
      { "id": "tokens_2000", "tokens": 2000, "amount": 5999, "label": "₹5,999", "badge": "SAVE" }
    ],
    "subscription_plans": [
      {
        "id": "free",
        "name": "Free",
        "price": "₹0",
        "price_inr": 0,
        "tokens": 0,
        "badge": null,
        "popular": false,
        "features": ["10 leads/day", "Basic lead feed", "Mobile app"]
      },
      {
        "id": "plan_starter",
        "name": "Starter",
        "price": "₹1,499/mo",
        "price_inr": 1499,
        "tokens": 500,
        "badge": null,
        "popular": false,
        "features": ["500 tokens/month", "AI draft messages", "Export leads"]
      },
      {
        "id": "plan_pro",
        "name": "Pro",
        "price": "₹4,999/mo",
        "price_inr": 4999,
        "tokens": 2500,
        "badge": "★ Popular",
        "popular": true,
        "features": ["2,500 tokens/month", "Unlimited queries", "Analytics dashboard"]
      },
      {
        "id": "plan_enterprise",
        "name": "Enterprise",
        "price": "Custom",
        "price_inr": 0,
        "tokens": 0,
        "badge": null,
        "popular": false,
        "features": ["Custom tokens", "Dedicated support", "SLA guarantee"]
      }
    ]
  },
  "settings": {
    "legal": {
      "terms": "https://indigenservices.com/terms",
      "privacy": "https://indigenservices.com/privacy",
      "dpdp": "https://indigenservices.com/dpdp"
    }
  },
  "feature_flags": {
    "show_swipe_stack": false,
    "show_ai_suggestions": true,
    "maintenance_mode": false
  }
